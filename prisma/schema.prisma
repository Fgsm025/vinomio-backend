  @@map("team_members")
}

model Professional {
  id         String   @id @default(uuid())
  farmId     String   @map("farm_id")
  name       String
  role       String
  phone      String?
  email      String?
  company    String?
  notes      String?
  rateType   String?  @map("rate_type")
  rateAmount Float?   @map("rate_amount")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

