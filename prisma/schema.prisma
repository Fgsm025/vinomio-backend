  @@map("clients")
}

/// CRM sale pipeline card (one row per deal / tarjeta)
model PipelineDeal {
  id            String   @id @default(uuid())
  farmId        String   @map("farm_id")
  stage         String
  sortOrder     Int      @default(0) @map("sort_order")
  name          String
  description   String?
  amount        Float
  quantity      Float?
  productId     String?  @map("product_id")
  priority      String
  progress      Int      @default(0)
  clientId      String?  @map("client_id")
  createDate    DateTime @map("create_date")
  closeDate     DateTime @map("close_date")
  lastUpdate    DateTime @map("last_update")
  owner         Json
  client        Json
  company       Json
  collaborators Json

  farm        Farm    @relation(fields: [farmId], references: [id], onDelete: Cascade)
  clientRef   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([farmId, stage])
  @@map("pipeline_deals")
}

model TraceabilityRecord {
