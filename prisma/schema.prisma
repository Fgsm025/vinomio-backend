  dosageUnit    String  @map("dosage_unit")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sprayRecord SprayRecord @relation(fields: [sprayRecordId], references: [id], onDelete: Cascade)
  supply      Supply?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([sprayRecordId])
  @@map("spray_record_products")
