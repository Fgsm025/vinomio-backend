model Client {
  id           String   @id @default(uuid())
  farmId       String   @map("farm_id")
  name         String
  company      String?
  email        String
  phone        String
  address      String?
  city         String?
  state        String?
  postalCode   String?  @map("postal_code")
  country      String?
