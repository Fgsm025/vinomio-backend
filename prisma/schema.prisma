  farm        Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  field       Field        @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  plot        Plot?        @relation(fields: [plotId], references: [id], onDelete: SetNull)
  diagnostics Diagnostic[]

  @@map("scouting_records")
}

model Diagnostic {
  id                     String   @id @default(uuid())
  farmId                 String   @map("farm_id")
  fieldId                String   @map("field_id")
  scoutingRecordId       String?  @map("scouting_record_id")
  animalId               String?  @map("animal_id")
  origin                 String
  diagnosisDate          DateTime @map("diagnosis_date") @db.Date
  problemType            String   @map("problem_type")
  problemIdentified      String   @map("problem_identified")
  symptoms               String
