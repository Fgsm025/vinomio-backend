  plot  Plot?  @relation(fields: [plotId], references: [id], onDelete: SetNull)

  @@map("traceability_records")
}

model SprayRecord {
  id                 String   @id @default(uuid())
  farmId             String   @map("farm_id")
  fieldId            String   @map("field_id")
  plotId             String?  @map("plot_id")
  plotIds            String[] @default([]) @map("plot_ids")
  date               DateTime @db.Date
  applicationType    String   @map("application_type")
  applicationMethod  String   @map("application_method")
  targetPestDisease  String?  @map("target_pest_disease")
  weatherConditions  String?  @map("weather_conditions")
  temperature        Float?
  windSpeed          Float?   @map("wind_speed")
  responsible        String
  areaApplied        Float    @map("area_applied")
  areaUnit           String   @map("area_unit")
  waterVolume        Float?   @map("water_volume")
  waterVolumeUnit    String?  @map("water_volume_unit")
  phi                Int?
